{
  "pluginAlias": "MonsterSmartLighting",
  "pluginType": "platform",
  "singular": true,
  "strictValidation": false,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Monster Smart Lighting"
      },
      "email": {
        "title": "Email",
        "type": "string",
        "required": true
      },
      "password": {
        "title": "Password",
        "type": "string",
        "required": true
      },
      "pollIntervalSeconds": {
        "title": "Poll Interval",
        "type": "integer",
        "default": 300,
        "minimum": 60,
        "description": "How often Homebridge polls Monster cloud state, in seconds. Minimum is 60 seconds."
      }
    }
  }
}